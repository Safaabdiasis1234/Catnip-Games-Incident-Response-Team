#!/usr/bin/env python3
import json
import sys
import time
import os
import requests
from typing import Any, Dict, Optional

# =========================
# CONFIG (EDIT THESE)
# =========================
CORTEX_URL = os.getenv("CORTEX_URL", "http://cortex:9001")
CORTEX_API_KEY = os.getenv("CORTEX_API_KEY", "PASTE_YOUR_CORTEX_API_KEY_HERE")

ANALYZERS = [
    "AbuseIPDB",
    "VirusTotal_GetReport",
    "Shodan",
]

POLL_INTERVAL_SECONDS = 2
POLL_TIMEOUT_SECONDS = 90
REQUEST_TIMEOUT_SECONDS = 20
# =========================

HEADERS = {
    "Authorization": f"Bearer {CORTEX_API_KEY}",
    "Content-Type": "application/json",
    "Accept": "application/json",
}


def safe_json_dumps(obj: Any) -> str:
    return json.dumps(obj, ensure_ascii=False, separators=(",", ":"))


def read_observable() -> Optional[str]:
    """
    Supports common Cortex analyzer invocation styles:
    1) argv[1] is a JSON file path containing {"data": "...", "dataType": "..."}
    2) argv[1] is the observable itself (e.g., "8.8.8.8")
    3) stdin JSON containing {"data": "..."} (optional but good for coursework compliance)
    """
    # 1) Cortex commonly passes a JSON file path as argv[1]
    if len(sys.argv) >= 2:
        arg = sys.argv[1]
        if isinstance(arg, str) and arg.endswith(".json"):
            try:
                with open(arg, "r", encoding="utf-8") as f:
                    content = json.load(f)
                data = content.get("data")
                return str(data).strip() if data else None
            except Exception:
                # If file read fails, fall back to treating arg as raw observable
                return arg.strip()
        return arg.strip()

    # 2) Optional: read JSON from stdin if provided
    try:
        if not sys.stdin.isatty():
            content = json.load(sys.stdin)
            data = content.get("data") or content.get("observable") or content.get("ip")
            return str(data).strip() if data else None
    except Exception:
        pass

    return None


def cortex_run_analyzer(analyzer_name: str, ip: str) -> str:
    payload = {
        "data": ip,
        "dataType": "ip",
        "tlp": 2,
        "pap": 2,
        "message": f"Auto-enrichment for {ip} using {analyzer_name}",
    }

    url = f"{CORTEX_URL.rstrip('/')}/api/analyzer/{analyzer_name}/run"
    r = requests.post(url, headers=HEADERS, json=payload, timeout=REQUEST_TIMEOUT_SECONDS)

    if r.status_code not in (200, 201):
        raise RuntimeError(
            f"Failed to start analyzer {analyzer_name}: HTTP {r.status_code} - {r.text[:300]}"
        )

    data = r.json()
    job_id = data.get("id") or data.get("_id") or data.get("jobId")
    if not job_id:
        raise RuntimeError(f"Could not read job id from Cortex response for {analyzer_name}: {data}")

    return str(job_id)


def cortex_wait_for_report(job_id: str) -> Dict[str, Any]:
    """
    Cortex report endpoint commonly:
      GET /api/job/{jobId}/report
    If report isn't ready, you may receive 404 for a short time.
    """
    url = f"{CORTEX_URL.rstrip('/')}/api/job/{job_id}/report"
    start = time.time()

    while True:
        if time.time() - start > POLL_TIMEOUT_SECONDS:
            return {"success": False, "error": f"Timeout waiting for job {job_id}"}

        r = requests.get(url, headers=HEADERS, timeout=REQUEST_TIMEOUT_SECONDS)

        if r.status_code == 404:
            time.sleep(POLL_INTERVAL_SECONDS)
            continue

        if r.status_code != 200:
            return {
                "success": False,
                "error": f"HTTP {r.status_code}",
                "details": r.text[:300],
            }

        try:
            report = r.json()
        except Exception:
            return {"success": False, "error": "Invalid JSON report", "details": r.text[:300]}

        return {"success": True, "report": report}


def build_output(ip: str, results: Dict[str, Dict[str, Any]]) -> Dict[str, Any]:
    ok = [name for name, res in results.items() if res.get("success") is True]
    failed = [name for name, res in results.items() if res.get("success") is not True]

    summary = f"Enriched {ip} with {len(ok)} analyzers. Failed: {len(failed)}."

    overall_level = "info"
    overall_value = "Enriched"

    # Lightweight heuristic: scan report JSON text for suspicious keywords
    suspicious_terms = [
        "malicious",
        "suspicious",
        "abuse confidence",
        "blacklist",
        "threat",
        "botnet",
        "c2",
        "command and control",
        "phishing",
    ]

    for _, res in results.items():
        rep = res.get("report") or {}
        rep_text = safe_json_dumps(rep).lower()
        if any(t in rep_text for t in suspicious_terms):
            overall_level = "suspicious"
            overall_value = "PotentialThreat"
            break

    taxonomies = [
        {
            "namespace": "SOC",
            "predicate": "Enrichment",
            "value": overall_value,
            "level": overall_level,
        }
    ]

    return {
        "summary": summary,
        "taxonomies": taxonomies,
        "full": {
            "observable": ip,
            "analyzers_requested": ANALYZERS,
            "success": ok,
            "failed": failed,
            "results": results,
        },
    }


def main() -> None:
    ip = read_observable()
    if not ip:
        print(safe_json_dumps({"error": "No observable provided"}))
        sys.exit(1)

    if CORTEX_API_KEY == "PASTE_YOUR_CORTEX_API_KEY_HERE" or not CORTEX_API_KEY.strip():
        print(
            safe_json_dumps(
                {
                    "error": "CORTEX_API_KEY is not set",
                    "hint": "Set env var CORTEX_API_KEY or edit the script config.",
                }
            )
        )
        sys.exit(1)

    results: Dict[str, Dict[str, Any]] = {}

    for analyzer in ANALYZERS:
        try:
            job_id = cortex_run_analyzer(analyzer, ip)
            results[analyzer] = cortex_wait_for_report(job_id)
        except Exception as e:
            results[analyzer] = {"success": False, "error": str(e)}

    output = build_output(ip, results)
    print(safe_json_dumps(output))


if __name__ == "__main__":
    main()
